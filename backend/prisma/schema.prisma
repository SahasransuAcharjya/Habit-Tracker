generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum TaskType {
  ONE_TIME
  RECURRING
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  PENDING
  COMPLETED
  MISSED
  SKIPPED
}

enum AssistantTone {
  MOTIVATIONAL
  BALANCED
  STRICT
  SAVAGE
}

enum HabitFrequency {
  DAILY
  WEEKLY
}

model User {
  id                      String                     @id @default(cuid())
  name                    String
  email                   String                     @unique
  passwordHash            String
  role                    UserRole                   @default(USER)
  assistantTone           AssistantTone              @default(BALANCED)
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt

  tasks                    Task[]
  habits                   Habit[]
  taskInstances            TaskInstance[]
  dailyReports             DailyReport[]
  notificationSubscriptions NotificationSubscription[]

  @@index([email])
}

model Task {
  id                String        @id @default(cuid())
  userId            String
  title             String
  description       String?
  category          String?
  type              TaskType      @default(ONE_TIME)
  priority          TaskPriority  @default(MEDIUM)

  startTime         DateTime?
  endTime           DateTime?
  dueDate           DateTime?

  isRecurring       Boolean       @default(false)
  recurrenceDays    Int[]         @default([])
  reminderEnabled   Boolean       @default(true)
  reminderInterval  Int?          // minutes
  autoMarkMissed    Boolean       @default(true)
  isActive          Boolean       @default(true)

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskInstances     TaskInstance[]

  @@index([userId])
  @@index([type])
  @@index([isActive])
}

model TaskInstance {
  id                String       @id @default(cuid())
  userId            String
  taskId            String
  scheduledDate     DateTime
  startTime         DateTime?
  endTime           DateTime?
  completedAt       DateTime?
  missedAt          DateTime?
  skippedAt         DateTime?
  status            TaskStatus   @default(PENDING)
  scoreAwarded      Int          @default(0)
  reminderSentCount Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  task              Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([taskId])
  @@index([scheduledDate])
  @@index([status])
  @@unique([taskId, scheduledDate])
}

model Habit {
  id                String          @id @default(cuid())
  userId            String
  title             String
  description       String?
  category          String?
  frequency         HabitFrequency  @default(DAILY)
  targetDays        Int[]           @default([])
  reminderTime      DateTime?
  streakCount       Int             @default(0)
  longestStreak     Int             @default(0)
  lastCompletedDate DateTime?
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([frequency])
  @@index([isActive])
}

model DailyReport {
  id                  String         @id @default(cuid())
  userId              String
  reportDate          DateTime
  totalTasks          Int            @default(0)
  completedTasks      Int            @default(0)
  missedTasks         Int            @default(0)
  skippedTasks        Int            @default(0)
  completionRate      Float          @default(0)
  score               Int            @default(0)
  summary             String?
  praiseMessage       String?
  warningMessage      String?
  motivationMessage   String?
  toneUsed            AssistantTone  @default(BALANCED)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([reportDate])
  @@unique([userId, reportDate])
}

model NotificationSubscription {
  id          String   @id @default(cuid())
  userId      String
  endpoint    String   @unique
  p256dh      String
  auth        String
  deviceName  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
}